{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "lib": ["DOM", "DOM.Iterable", "ESNext"],
    "rootDir": "./script/src",
    "outDir": "./script/dist",
    "strict": true,
    "noImplicitAny": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "moduleResolution": "node",
    "sourceMap": false,
	 "removeComments": true
  },
  "include": ["script/src/**/*.ts"],
  "exclude": ["node_modules"]
}